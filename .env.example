# AsuraVerse Esports Website — Environment Variables
# Copy this file to .env and fill in your values

# ── Server ──────────────────────────────────────────────────────────────
PORT=3000

# ── Email (Gmail SMTP) ──────────────────────────────────────────────────
# The Gmail address used to SEND emails
EMAIL_USER=your_gmail@gmail.com

# Gmail App Password (NOT your account password).
# Enable 2-Step Verification, then generate an App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_PASS=your_16_char_app_password

# The address that receives all form submission notifications
ADMIN_EMAIL=teamasuraverse@gmail.com
